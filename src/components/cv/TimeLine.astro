---
const { title, subtitle } = Astro.props;
---

<div class="flex group">
  <div class="education__time flex flex-col items-center">
    <span class="w-4 h-4 bg-[#00f0ff] rounded-full mt-1 shadow-[0_0_10px_rgba(0,240,255,0.3)] transition-all duration-300 group-hover:shadow-[0_0_20px_rgba(0,240,255,0.5)]"></span>
    <span class="education__line bg-gradient-to-b from-[rgba(0,240,255,0.3)] to-transparent block h-full w-[2px] translate-x-0"></span>
  </div>
  <div class="experience__data bd-grid px-5 pb-8">
    <h3 class="font-heading font-semibold mb-1 text-base-content/90 group-hover:text-[#00f0ff] transition-colors duration-200">{title}</h3>
    <span class="font-body text-sm text-base-content/40">{subtitle}</span>
    <p class="my-2 text-justify font-body text-base-content/60 leading-relaxed">
      <slot />
    </p>
  </div>
</div>
