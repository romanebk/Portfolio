---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div class="reveal reveal-delay-1">
    <div class="text-3xl w-full font-bold mb-5">Tous mes projets</div>
    <p class="text-lg mb-8">Une sélection de projets réalisés à EPITECH et en freelance.</p>
  </div>

  <div class="text-2xl font-bold mb-3 mt-8 reveal reveal-delay-2">AIA — Intelligence Artificielle</div>

  <HorizontalCard
    title="Startrek"
    img="/post_img.webp"
    desc="Apprentissage par renforcement (DQN) pour atterrissage lunaire. Entraînement d'un agent sur LunarLander-v3 avec PyTorch et Gymnasium. Politique epsilon-greedy, réseaux de neurones, visualisation des performances."
    url="#"
    badge="Python/PyTorch"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Codename"
    img="/post_img.webp"
    desc="Prompt engineering : attaque et défense de LLM. Utilisation de granite3.1-moe via Ollama pour tester les injections de prompts, jailbreaks et mécanismes de défense."
    url="#"
    badge="LLM"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Persona (n8n)"
    img="/post_img.webp"
    desc="Plateforme d'automatisation n8n avec PostgreSQL et Mistral AI. Workflows automatisés, intégration IA, pipeline de données."
    url="#"
    badge="n8n/IA"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="persona_me"
    img="/post_img.webp"
    desc="Agrégateur de news personnalisé avec chatbot Mistral AI. Authentification, newsletter RSS, conformité GDPR, interface moderne."
    url="#"
    badge="Fullstack"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Level Up RPG"
    img="/post_img.webp"
    desc="Jeu éducatif RPG avec React 19/Electron/TailwindCSS. Combats par défis (mathématiques, lecture, culture générale), système de niveaux et d'XP."
    url="#"
    badge="React/Electron"
  />

  <div class="text-2xl font-bold mb-3 mt-10">OOP — Programmation Orientée Objet</div>

  <HorizontalCard
    title="Arcade"
    img="/post_img.webp"
    desc="Plateforme de jeux dynamique avec plugins .so partagés. 3 jeux (Snake/Nibbler/Minesweeper), 3 bibliothèques graphiques (NCurses/SDL2/SFML). Architecture modulaire en C++."
    url="#"
    badge="C++"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Raytracer"
    img="/post_img.webp"
    desc="Moteur de rendu 3D supportant sphères, plans, cylindres, cônes et lumières. Multithreading, parsing de scènes .cfg, sauvegarde BMP. Architecture orientée objet en C++."
    url="#"
    badge="C++"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Nanotekspice"
    img="/post_img.webp"
    desc="Simulateur de circuits numériques. Portes AND/OR/XOR/NOT/NAND/NOR, tristate, CLI interactif. Parsing de fichiers .nts, simulation pas à pas."
    url="#"
    badge="C++"
  />

  <div class="text-2xl font-bold mb-3 mt-10">CCP — Programmation Concurrente</div>

  <HorizontalCard
    title="Panoramix"
    img="/post_img.webp"
    desc="Simulation Astérix avec threads pthread, mutex et sémaphores. Druide, villageois, gestion de la potion magique — synchronisation avancée en C."
    url="#"
    badge="C/Threads"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Plazza"
    img="/post_img.webp"
    desc="Pizzéria multithreadée en C++17. Processus, pipes nommés, thread pool, 12 design patterns (Singleton, Factory, Observer, etc.). Architecture modulaire."
    url="#"
    badge="C++17"
  />

  <div class="text-2xl font-bold mb-3 mt-10">NTW — Réseau</div>

  <HorizontalCard
    title="myFTP"
    img="/post_img.webp"
    desc="Serveur FTP conforme RFC 959. Implémentation avec poll + fork, transferts de fichiers, authentification, commandes standards (LIST, RETR, STOR, etc.)."
    url="#"
    badge="C/Réseau"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="myTeams"
    img="/post_img.webp"
    desc="Plateforme collaborative Teams-like : users, teams, channels, threads, comments, messaging. Protocole JSON/TCP, sauvegarde persistante, events push."
    url="#"
    badge="C/Réseau"
  />

  <div class="text-2xl font-bold mb-3 mt-10">MATH — Mathématiques & Signal</div>

  <HorizontalCard
    title="StoneAnalysis"
    img="/post_img.webp"
    desc="Analyse fréquentielle audio avec FFT (Cooley-Tukey + Bluestein). Stéganographie dans fichiers WAV. Traitement du signal en C++."
    url="#"
    badge="C++/DSP"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Interstonar"
    img="/post_img.webp"
    desc="Simulation 3D de trajectoire spatiale. Gravitation Newtonienne, ray marching SDF, intégration Euler. Visualisation graphique des orbites."
    url="#"
    badge="C++/3D"
  />

  <div class="text-2xl font-bold mb-3 mt-10">SEC — Sécurité</div>

  <HorizontalCard
    title="CTF Bug Bounty - ECorp"
    img="/post_img.webp"
    desc="11 challenges d'exploitation binaire avec write-ups et PoCs : stack overflow, variable overwrite, ret2func, shellcode, ASLR bypass, heap overflow (function pointer/GOT overwrite), Use-After-Free (tcache)."
    url="#"
    badge="Python/C"
  />

  <div class="text-2xl font-bold mb-3 mt-10">Autres projets</div>

  <HorizontalCard
    title="Serveur TCP Chat"
    img="/post_img.webp"
    desc="Serveur TCP chat en C avec poll(). Gestion non-bloquante de multiples clients, buffers de lecture/écriture, Makefile, max 100 clients."
    url="#"
    badge="C"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="ShieldAI"
    img="/post_img.webp"
    desc="Pitch deck startup — cybersécurité IA pour PME africaines. Analyse de marché, business model, stratégie de déploiement."
    url="#"
    badge="Startup"
  />
</BaseLayout>
