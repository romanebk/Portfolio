---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="min-h-[70vh] flex flex-col justify-center reveal reveal-delay-1 hero-parallax relative">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[rgba(0,240,255,0.2)] bg-[rgba(0,240,255,0.05)] text-sm font-body w-fit mb-6 animate-pulse-glow">
      <span class="w-2 h-2 rounded-full bg-[#00f0ff]"></span>
      Disponible pour des projets
    </div>

    <h1 class="text-6xl md:text-7xl xl:text-8xl font-heading font-bold leading-tight">
      Ariel
      <span class="gradient-text">BOKO</span>
    </h1>

    <p class="text-xl md:text-2xl text-base-content/70 mt-4 font-body max-w-2xl">
      Développeur <span class="text-[#00f0ff] font-semibold">C++/C</span>,
      <span class="text-[#ff00e5] font-semibold">Web</span>,
      <span class="text-[#8b5cf6] font-semibold">Rust</span>,
      <span class="text-[#3b82f6] font-semibold">Python</span>
    </p>

    <p class="text-base md:text-lg text-base-content/50 mt-3 font-body max-w-xl leading-relaxed">
      Passionné par la cybersécurité, l'IA et le développement logiciel.
      Je relève tous les défis techniques, des algorithmes bas niveau aux architectures web modernes.
    </p>

    <div class="flex flex-wrap gap-4 mt-10">
      <a href="/projects" class="btn btn-primary rounded-full px-6 font-heading font-medium">
        Voir mes projets
      </a>
      <a href="/cv" class="btn btn-outline rounded-full px-6 font-heading font-medium border-base-content/20 hover:border-[#ff00e5] hover:text-[#ff00e5]">
        Mon CV
      </a>
      <a href="/contact" class="btn btn-ghost rounded-full px-6 font-heading font-medium text-base-content/50 hover:text-base-content">
        Me contacter →
      </a>
    </div>
  </div>

  <div class="mt-16 mb-6 reveal reveal-delay-3">
    <div class="flex items-center gap-3">
      <h2 class="text-2xl md:text-3xl font-heading font-bold">Projets phares</h2>
      <span class="text-2xl font-heading gradient-text">{">"}</span>
      <div class="h-px flex-1 bg-gradient-to-r from-[rgba(0,240,255,0.2)] to-transparent"></div>
    </div>
  </div>

  <div class="reveal reveal-delay-1">
    <HorizontalCard
      title="Arcade"
      img="/projects/arcade.webp"
      desc="Plateforme de jeux dynamique avec plugins .so (Snake/Nibbler/Minesweeper), 3 affichages (NCurses/SDL2/SFML) - C++"
      url="#"
      badge="C++"
    />
  </div>
  <div class="divider my-0 border-base-content/10" />
  <div class="reveal reveal-delay-2">
    <HorizontalCard
      title="Raytracer"
      img="/projects/raytracer.webp"
      desc="Moteur de rendu 3D (sphères, plans, cylindres, cônes, lumières) avec multithreading, scènes .cfg - C++"
      url="#"
      badge="C++"
    />
  </div>
  <div class="divider my-0 border-base-content/10" />
  <div class="reveal reveal-delay-3">
    <HorizontalCard
      title="Startrek"
      img="/projects/startrek.webp"
      desc="Apprentissage par renforcement (DQN) pour atterrissage lunaire - Python/PyTorch/Gymnasium"
      url="#"
      badge="AI"
    />
  </div>
  <div class="divider my-0 border-base-content/10" />
  <div class="reveal reveal-delay-1">
    <HorizontalCard
      title="CTF Bug Bounty - ECorp"
      img="/projects/ecorp.webp"
      desc="11 challenges d'exploitation binaire : stack overflow, ASLR bypass, heap overflow, Use-After-Free - Python/C"
      url="#"
      badge="SEC"
    />
  </div>
  <div class="divider my-0 border-base-content/10" />
  <div class="reveal reveal-delay-2">
    <HorizontalCard
      title="Level Up RPG"
      img="/projects/levelup.webp"
      desc="Jeu éducatif RPG React 19/Electron/TailwindCSS avec combats par défis (math, lecture, etc.)"
      url="#"
      badge="WEB"
    />
  </div>

  <div class="mt-12 text-center reveal reveal-delay-4">
    <a href="/projects" class="btn btn-outline btn-lg rounded-full px-8 font-heading border-base-content/20 hover:border-[#00f0ff] hover:text-[#00f0ff] group">
      Voir tous les projets
      <span class="inline-block transition-transform group-hover:translate-x-1 ml-1">→</span>
    </a>
  </div>
</BaseLayout>
