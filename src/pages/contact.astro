---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" sideBarActiveItemID="contact">
  <div class="reveal reveal-delay-1">
    <div class="text-3xl w-full font-heading font-bold mb-5">Contact</div>
    <p class="text-lg mb-8 font-body text-base-content/60">Une question, un projet ? N'hésite pas à me contacter.</p>
  </div>

  <div class="flex flex-col md:flex-row gap-8">
    <div class="md:w-1/2 reveal reveal-delay-2">
      <div class="glass rounded-xl p-6">
        <h3 class="text-xl font-heading font-bold mb-6">Mes coordonnées</h3>

        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-lg bg-[rgba(0,240,255,0.1)] flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00f0ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div>
            <p class="font-semibold font-heading text-sm text-base-content/40">Email</p>
            <a href="mailto:r.b.arielbokobeni@gmail.com" class="link link-hover font-body">r.b.arielbokobeni@gmail.com</a>
          </div>
        </div>

        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-lg bg-[rgba(139,92,246,0.1)] flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p class="font-semibold font-heading text-sm text-base-content/40">Localisation</p>
            <p class="font-body">Cotonou, Bénin</p>
          </div>
        </div>

        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-lg bg-[rgba(255,0,229,0.1)] flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#ff00e5"><path d="M12.026 2c-5.509 0-9.974 4.465-9.974 9.974 0 4.406 2.857 8.145 6.821 9.465.499.09.679-.217.679-.481 0-.237-.008-.865-.011-1.696-2.775.602-3.361-1.338-3.361-1.338-.452-1.152-1.107-1.459-1.107-1.459-.905-.619.069-.605.069-.605 1.002.07 1.527 1.028 1.527 1.028.89 1.524 2.336 1.084 2.902.829.091-.645.351-1.085.635-1.334-2.214-.251-4.542-1.107-4.542-4.93 0-1.087.389-1.979 1.024-2.675-.101-.253-.446-1.268.099-2.64 0 0 .837-.269 2.742 1.021a9.582 9.582 0 0 1 2.496-.336 9.554 9.554 0 0 1 2.496.336c1.906-1.291 2.742-1.021 2.742-1.021.545 1.372.203 2.387.099 2.64.64.696 1.024 1.587 1.024 2.675 0 3.833-2.33 4.675-4.552 4.922.355.308.675.916.675 1.846 0 1.334-.012 2.41-.012 2.737 0 .267.178.577.687.479C19.146 20.115 22 16.379 22 11.974 22 6.465 17.535 2 12.026 2z"/></svg>
          </div>
          <div>
            <p class="font-semibold font-heading text-sm text-base-content/40">GitHub</p>
            <a href="https://github.com/romanebk" target="_blank" class="link link-hover font-body">github.com/romanebk</a>
          </div>
        </div>

        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-lg bg-[rgba(0,240,255,0.1)] flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#00f0ff"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </div>
          <div>
            <p class="font-semibold font-heading text-sm text-base-content/40">Facebook</p>
            <a href="https://www.facebook.com/romane.bk.2025" target="_blank" class="link link-hover font-body">facebook.com/romane.bk.2025</a>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-[rgba(0,240,255,0.1)] flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="#00f0ff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <div>
            <p class="font-semibold font-heading text-sm text-base-content/40">WhatsApp</p>
            <a href="https://wa.me/2290153221060" target="_blank" class="link link-hover font-body">+229 01 53 22 10 60</a>
          </div>
        </div>
      </div>
    </div>

    <div class="md:w-1/2 reveal reveal-delay-3">
      <form id="contactForm" action="/api/contact" method="post" class="glass rounded-xl p-6">
        <h3 class="text-xl font-heading font-bold mb-6">Envoyer un message</h3>

        <div id="formStatus" class="hidden mb-4 p-3 rounded-lg text-sm font-body"></div>

        <div class="form-control mb-4">
          <label class="label" for="name">
            <span class="label-text font-body text-base-content/60">Nom</span>
          </label>
          <input type="text" name="name" id="name" placeholder="Ton nom" class="input input-bordered bg-base-200/50 border-base-content/10 focus:border-[#00f0ff] transition-colors w-full" required />
        </div>

        <div class="form-control mb-4">
          <label class="label" for="email">
            <span class="label-text font-body text-base-content/60">Email</span>
          </label>
          <input type="email" name="email" id="email" placeholder="ton@email.com" class="input input-bordered bg-base-200/50 border-base-content/10 focus:border-[#00f0ff] transition-colors w-full" required />
        </div>

        <div class="form-control mb-4">
          <label class="label" for="subject">
            <span class="label-text font-body text-base-content/60">Sujet</span>
          </label>
          <input type="text" name="subject" id="subject" placeholder="Sujet de ton message" class="input input-bordered bg-base-200/50 border-base-content/10 focus:border-[#00f0ff] transition-colors w-full" />
        </div>

        <div class="form-control mb-6">
          <label class="label" for="message">
            <span class="label-text font-body text-base-content/60">Message</span>
          </label>
          <textarea name="message" id="message" rows="5" placeholder="Ton message..." class="textarea textarea-bordered bg-base-200/50 border-base-content/10 focus:border-[#00f0ff] transition-colors w-full" required></textarea>
        </div>

        <button type="submit" id="submitBtn" class="btn btn-primary w-full rounded-lg font-heading font-medium">Envoyer</button>
      </form>

      <script>
        const form = document.getElementById('contactForm');
        const status = document.getElementById('formStatus');
        const submitBtn = document.getElementById('submitBtn');

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          status.className = 'hidden';
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<span class="loading loading-spinner"></span> Envoi...';

          try {
            const res = await fetch('/api/contact', {
              method: 'POST',
              body: new FormData(form),
            });
            const data = await res.json();

            if (res.ok) {
              status.className = 'mb-4 p-3 rounded-lg text-sm font-body bg-green-500/10 text-green-400 border border-green-500/20';
              status.textContent = 'Message envoye avec succes !';
              form.reset();
            } else {
              throw new Error(data.error || 'Erreur');
            }
          } catch (err) {
            status.className = 'mb-4 p-3 rounded-lg text-sm font-body bg-red-500/10 text-red-400 border border-red-500/20';
            status.textContent = err.message || 'Erreur lors de l\'envoi. Reessaie.';
          } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Envoyer';
          }
        });
      </script>
    </div>
  </div>
</BaseLayout>
