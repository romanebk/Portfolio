    {
      "id": "0d18d9a7-a939-472f-a82a-9afabf6072c7",
      "name": "Build Prefs Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        1152
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const cur = $input.first() ? $input.first().json : {};\nconst req = $('Check Auth').first().json;\nconst email = String(req.email || '');\nlet nbFinal;\nif (req.nb_articles != null && !isNaN(Number(req.nb_articles))) { nbFinal = Number(req.nb_articles); }\nelse if (cur.nb_articles != null && cur.nb_articles !== '' && !isNaN(Number(cur.nb_articles))) { nbFinal = Number(cur.nb_articles); }\nelse { nbFinal = 6; }\nif (nbFinal < 1) { nbFinal = 1; }\nif (nbFinal > 10) { nbFinal = 10; }\nconst reqTone = String(req.tone || '').trim();\nconst toneFinal = reqTone ? reqTone : String(cur.tone || '');\nconst reqFmt = String(req.format || '').trim();\nconst fmtFinal = reqFmt ? reqFmt : String(cur.format || '');\nreturn [{ json: { email: email, nb_articles: nbFinal, tone: toneFinal, format: fmtFinal } }];"
      }
    },
