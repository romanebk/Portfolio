    {
      "id": "c93035ba-f207-4019-b38c-1d13286b3282",
      "name": "Check Auth",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        608
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const t = $('Profile Trigger').first().json;\nconst rows = $input.all();\nconst now = Date.now();\nlet authenticated = false;\nlet email = '';\nif (rows.length) {\n  const s = rows[0].json;\n  const verified = (s.verified === true || s.verified === 'true' || s.verified === 1);\n  const notExpired = !s.expires_at || new Date(s.expires_at).getTime() > now;\n  if (verified && notExpired) { authenticated = true; email = String(s.email || ''); }\n}\nreturn [{ json: {\n  authenticated,\n  email,\n  action: String(t.action || ''),\n  interests: t.interests != null ? String(t.interests) : '',\n  send_hour: t.send_hour != null && t.send_hour !== '' ? Number(t.send_hour) : null,\n  timezone: t.timezone != null ? String(t.timezone) : '',\n  nb_articles: t.nb_articles != null && t.nb_articles !== '' ? Number(t.nb_articles) : null,\n  tone: t.tone != null ? String(t.tone) : '',\n  format: t.format != null ? String(t.format) : ''\n} }];"
      }
    },
