    {
      "id": "cf1803ec-1f57-4895-b2e5-bd42a4854c0e",
      "name": "Validate OTP",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        288
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const t = $('Persona Backend Trigger').first().json;\nconst submitted = String(t.code || '').trim();\nconst sessionId = String(t.sessionId || '').trim();\nconst rows = $input.all();\nconst pepper = 'persona_pepper_v1';\nconst nowIso = new Date().toISOString();\nconst sessionExpires = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString();\nconst unsubToken = (Math.random().toString(36).slice(2) + Math.random().toString(36).slice(2)).slice(0, 24);\nfunction simpleHash(str) {\n  let hash = 5381;\n  for (let i = 0; i < str.length; i++) {\n    hash = ((hash << 5) + hash) ^ str.charCodeAt(i);\n    hash = hash >>> 0;\n  }\n  let h = hash.toString(16).padStart(8, '0');\n  let full = '';\n  for (let i = 0; i < 8; i++) { full += h; }\n  return full;\n}\nif (!rows.length) {\n  return [{ json: { ok: false, reason: 'no_pending_code', sessionId, attempts: 0, nowIso, sessionExpires, unsubToken } }];\n}\nconst row = rows[0].json;\nconst attempts = Number(row.attempts || 0);\nif (attempts >= 3) {\n  return [{ json: { ok: false, reason: 'too_many_attempts', sessionId, email: row.email, attempts: attempts, nowIso, sessionExpires, unsubToken } }];\n}\nconst expired = new Date(row.expires_at).getTime() < Date.now();\nconst submittedHash = simpleHash(submitted + pepper);\nconst match = submittedHash === row.code_hash;\nconst ok = !expired && match;\nreturn [{ json: { ok, reason: expired ? 'expired' : (match ? 'valid' : 'wrong_code'), sessionId, email: row.email, attempts: attempts + 1, nowIso, sessionExpires, unsubToken } }];"
      }
    },
