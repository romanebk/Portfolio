    {
      "id": "0292c395-530a-42ff-b1bf-caf82ba98b62",
      "name": "Generate OTP",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const input = $input.first().json;\nconst sessionId = String(input.sessionId || '').trim();\nconst email = String(input.email || '').trim().toLowerCase();\nif (!email || !/^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$/.test(email)) {\n  throw new Error('invalid_email');\n}\nconst code = String(Math.floor(100000 + Math.random() * 900000));\nconst pepper = 'persona_pepper_v1';\n// Simple hash without crypto module\nfunction simpleHash(str) {\n  let hash = 5381;\n  for (let i = 0; i < str.length; i++) {\n    hash = ((hash << 5) + hash) ^ str.charCodeAt(i);\n    hash = hash >>> 0;\n  }\n  let h = hash.toString(16).padStart(8, '0');\n  // extend to 64 chars\n  let full = '';\n  for (let i = 0; i < 8; i++) { full += h; }\n  return full;\n}\nconst codeHash = simpleHash(code + pepper);\nconst expiresAt = new Date(Date.now() + 5 * 60 * 1000).toISOString();\nreturn [{ json: { sessionId, email, code, code_hash: codeHash, expires_at: expiresAt, attempts: 0 } }];"
      }
    },
